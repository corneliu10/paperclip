# BirdAI application runtime
# Set DATABASE_URL for managed PostgreSQL in steady-state production.
# Leave it blank during initial validation if you want docker-compose.validation.yml
# to start a local Postgres container on the Droplet instead.
DATABASE_URL=
BETTER_AUTH_SECRET=replace-with-a-long-random-secret
BIRDAI_PUBLIC_URL=http://203.0.113.10:3100
BIRDAI_DEPLOYMENT_MODE=authenticated
BIRDAI_DEPLOYMENT_EXPOSURE=public
HOST=0.0.0.0
PORT=3100
BIRDAI_INSTANCE_ID=default
BIRDAI_CONFIG=/birdai/instances/default/config.json

# Docker Compose settings
BIRDAI_PORT=3100
BIRDAI_DATA_DIR=./data/digitalocean-birdai
VALIDATION_DB_USER=birdai
VALIDATION_DB_PASSWORD=birdai
VALIDATION_DB_NAME=birdai
VALIDATION_DB_DATA_DIR=./data/digitalocean-postgres

# Optional provider keys for local adapters running on the VPS
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Final public HTTPS setup
BIRDAI_DOMAIN=birdai.example.com
ACME_EMAIL=ops@example.com
CADDY_HTTP_PORT=80
CADDY_HTTPS_PORT=443
BIRDAI_CADDY_DATA_DIR=./data/caddy-data
BIRDAI_CADDY_CONFIG_DIR=./data/caddy-config
